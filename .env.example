# Copy to .env and fill in real values: cp .env.example .env
# Do not commit .env. Do not set VITE_API_URL for same-origin production builds.

POSTGRES_DB=icas_cmu_hub
POSTGRES_USER=icas_user
POSTGRES_PASSWORD=change-me-strong-password

DATABASE_URL=postgresql://icas_user:change-me-strong-password@database:5432/icas_cmu_hub?sslmode=disable

NODE_ENV=production
PORT=5000
CORS_ORIGIN=https://your-domain.example

JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret
JWT_EXPIRES_IN=7d

CHAT_ENCRYPTION_KEY=change-me-32-byte-or-longer-secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cmu.ac.th
